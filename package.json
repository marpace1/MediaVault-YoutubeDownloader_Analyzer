{
  "name": "mediavault",
  "version": "2.0.0",
  "description": "MediaVault — a premium desktop YouTube download manager built with Electron, React & TypeScript.",
  "author": {
    "name": "MediaVault",
    "email": "marpaceamv@gmail.com"
  },
  "homepage": "https://github.com/marpace1/MediaVault-YoutubeDownloader_Analyzer",
  "license": "MIT",
  "main": "dist-electron/main/index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/check-binaries.mjs && tsc --noEmit && vite build && electron-builder",
    "build:win": "node scripts/check-binaries.mjs && tsc --noEmit && vite build && electron-builder --win --x64",
    "build:mac": "node scripts/check-binaries.mjs && tsc --noEmit && vite build && electron-builder --mac",
    "build:linux": "node scripts/check-binaries.mjs && tsc --noEmit && vite build && electron-builder --linux",
    "preview": "vite preview",
    "check-binaries": "node scripts/check-binaries.mjs",
    "fetch-binaries": "node scripts/fetch-binaries.mjs",
    "fetch-binaries:all": "node scripts/fetch-binaries.mjs --all",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "electron-updater": "^6.3.9",
    "framer-motion": "^11.11.1",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^1.8.10",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^32.1.2",
    "electron-builder": "^25.1.7",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "app.mediavault.desktop",
    "productName": "MediaVault",
    "copyright": "Copyright © 2026 MediaVault",
    "directories": {
      "output": "release/${version}",
      "buildResources": "build"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "resources/bin/${os}",
        "to": "bin",
        "filter": ["**/*", "!.gitkeep"]
      }
    ],
    "asarUnpack": ["**/*.node"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MediaVault"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.png",
      "category": "AudioVideo",
      "maintainer": "MediaVault"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "your-org",
        "repo": "mediavault"
      }
    ]
  }
}
